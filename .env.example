# =============================================================================
# TalentBridge — Environment Variables
# Copy this file to .env and fill in real values.
# All defaults below work out of the box with docker compose up --build.
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER=talentbridge
POSTGRES_PASSWORD=talentbridge_dev_password
POSTGRES_DB=talentbridge
# Constructed by the api service; change host only if running db externally.
DATABASE_URL=postgresql+asyncpg://talentbridge:talentbridge_dev_password@db:5432/talentbridge

# --- Redis ---
REDIS_PASSWORD=redis_dev_password
REDIS_URL=redis://:redis_dev_password@redis:6379/0

# --- JWT ---
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=change_me_generate_with_openssl_rand_hex_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- bcrypt cost ---
BCRYPT_ROUNDS=12

# --- CORS (comma-separated list of allowed frontend origins) ---
CORS_ORIGINS=http://localhost:3000

# --- MailHog (dev SMTP catcher) ---
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_ADDRESS=noreply@talentbridge.local
EMAILS_FROM_NAME=TalentBridge

# --- File uploads ---
UPLOAD_DIR=/app/uploads/resumes
MAX_UPLOAD_SIZE_MB=10

# --- Rate limiting (slowapi) ---
RATE_LIMIT_AUTH=5/5minutes

# --- Next.js public vars (prefix NEXT_PUBLIC_ to expose to browser) ---
NEXT_PUBLIC_API_URL=http://api:8000

# --- Feature flags ---
# Set to "true" to enable LLM-assisted JD writer (requires OPENAI_API_KEY)
ENABLE_LLM_JD_WRITER=false
OPENAI_API_KEY=

# --- Seed data (used by app/db/seed.py) ---
SEED_HR_EMAIL=hr@test.com
SEED_HR_PASSWORD=Hr@12345
SEED_CANDIDATE_EMAIL=candidate@test.com
SEED_CANDIDATE_PASSWORD=Candidate@12345

# --- Environment ---
APP_ENV=development
LOG_LEVEL=INFO
