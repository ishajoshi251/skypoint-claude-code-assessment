# =============================================================================
# TalentBridge .gitignore
# =============================================================================

# --- Secrets / env ---
.env
.env.local
.env.*.local

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.venv/
venv/
env/
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg
.pytest_cache/
.ruff_cache/
.mypy_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover

# --- Node / Next.js ---
node_modules/
.next/
out/
.turbo/
.vercel/
*.tsbuildinfo
next-env.d.ts
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Docker build artifacts ---
.dockerignore

# --- Uploads (runtime-generated, stored in Docker volume) ---
backend/uploads/

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# --- Logs ---
*.log
logs/

# --- SSH keys (accidentally present in repo root) ---
pem
pem.pub

# --- spaCy / ML model caches ---
*.pkl
*.bin
